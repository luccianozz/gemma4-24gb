# Copy to .env and fill in.
# Get token: https://huggingface.co/settings/tokens (read scope)
# Accept license first: https://huggingface.co/google/gemma-4-12B-it-qat-w4a16-ct
HF_TOKEN=hf_your_token_here

# vLLM endpoint auth. Any string. Clients must send: Authorization: Bearer <this>
VLLM_API_KEY=change-me-to-random-string
